#!/bin/sh
# ─────────────────────────────────────────────────────────────────────────────
# "done = green" commit gate  ·  agent-work-ethic Level 4
#
# Blocks the commit unless your build / tests / lint all pass. This is what makes
# "done" mean *verified* instead of *claimed* — the agent (or you) literally
# cannot commit broken code. Pairs with the work-ethic rule "evidence, not
# assertion": the gate IS the evidence.
#
# INSTALL (per project, ~30s):
#   mkdir -p .githooks
#   cp /path/to/agent-work-ethic/commit-gate/pre-commit.template .githooks/pre-commit
#   chmod +x .githooks/pre-commit
#   git config core.hooksPath .githooks
# Then fill in the three commands below for your stack.
#
# Emergency bypass (use sparingly — it ships unverified):  git commit --no-verify
# ─────────────────────────────────────────────────────────────────────────────

# 1) SET YOUR COMMANDS. Leave a variable empty ("") to skip that step.
#    Node/npm example (delete what you don't use):
BUILD_CMD="npm run build"
TEST_CMD="npm test"
LINT_CMD="npm run lint"
#    Other stacks — replace the three lines above with yours, e.g.:
#      Python:  BUILD_CMD=""            TEST_CMD="pytest -q"        LINT_CMD="ruff check ."
#      Rust:    BUILD_CMD="cargo build" TEST_CMD="cargo test"      LINT_CMD="cargo clippy -- -D warnings"
#      Go:      BUILD_CMD="go build ./..." TEST_CMD="go test ./..." LINT_CMD="go vet ./..."

# 2) Skip inside CI (CI runs its own checks).
[ -n "$CI" ] && exit 0

# 3) Docs-only fast-path: if EVERY staged file is markdown, it can't affect
#    build/test/lint — skip the gate so doc edits stay instant. Any non-.md file
#    (including a deleted source file) falls through and runs the full gate.
STAGED=$(git diff --cached --name-only)
NON_DOC=$(printf '%s\n' "$STAGED" | grep -vE '\.md$')
if [ -n "$STAGED" ] && [ -z "$NON_DOC" ]; then
  printf '\n[gate] Docs-only (markdown) change — skipping build/test/lint.\n\n'
  exit 0
fi

# 4) Run each step fast-fail (cheapest first). Abort the commit on the first failure.
run_step() {
  # $1 = label, $2 = command
  [ -z "$2" ] && return 0                       # empty command → step disabled
  log="/tmp/gate-$1.log"
  if ! sh -c "$2" >"$log" 2>&1; then
    printf '\n❌ %s FAILED — commit aborted. Last lines:\n' "$1"
    tail -20 "$log"
    printf '\nFull log: %s\n' "$log"
    exit 1
  fi
  printf '  ✓ %s\n' "$1"
}

printf '\n[gate] build → tests → lint (bypass with --no-verify)\n\n'
run_step build "$BUILD_CMD"
run_step tests "$TEST_CMD"
run_step lint  "$LINT_CMD"
printf '\n✅ Gate passed — committing.\n\n'

# Optional: to auto-stage everything before the gate (opinionated — it commits
# ALL working-tree changes, not just what you `git add`ed), put `git add -A` as
# the FIRST line after the shebang. Off by default so the gate only judges what
# you chose to stage.
